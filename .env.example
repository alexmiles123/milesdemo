# ─── Public (safe to expose client-side via Vite VITE_ prefix if needed) ───
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=<anon key from Supabase — Settings → API>

# ─── Server-only (Vercel env, NEVER prefix with VITE_) ───
SUPABASE_SERVICE_KEY=<service_role key from Supabase — Settings → API>
APP_URL=https://monument.example.com

# ─── Integrations (set only after configuring through the UI) ───
TEAMS_CLIENT_SECRET=
SALESFORCE_CLIENT_SECRET=

# ─── Alerting ───
ALERT_FROM_EMAIL=monument-alerts@yourdomain.com
ALERT_TO_EMAILS=csm-ops@yourdomain.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# ─── Optional: durable rate-limit (Upstash Redis / Vercel KV) ───
# If unset, API routes fall back to an in-memory limiter scoped per-region.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
